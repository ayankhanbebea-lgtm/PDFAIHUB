# ================================================
# PDFAI Hub — Environment Variables
# Copy this to .env.local and fill in your values
# ================================================

# ── App ──────────────────────────────────────────
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_APP_NAME="PDFAI Hub"
NODE_ENV=development

# ── NextAuth ─────────────────────────────────────
# Generate secret: openssl rand -base64 32
NEXTAUTH_SECRET=your-32-character-secret-here
NEXTAUTH_URL=http://localhost:3000

# ── Database (PostgreSQL) ────────────────────────
# Free options: Neon (neon.tech) or Supabase (supabase.com)
DATABASE_URL=postgresql://user:password@localhost:5432/pdfai_hub

# ── Google OAuth ─────────────────────────────────
# Setup: console.cloud.google.com → APIs & Services → Credentials
# Authorized redirect URIs: http://localhost:3000/api/auth/callback/google
GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=GOCSPX-your-google-client-secret

# ── OpenAI ───────────────────────────────────────
# Get key: platform.openai.com/api-keys
OPENAI_API_KEY=sk-proj-your-openai-key

# ── Google Gemini ─────────────────────────────────
# Get key: makersuite.google.com/app/apikey
GEMINI_API_KEY=your-gemini-api-key

# ── Cloudinary (File Storage) ────────────────────
# Free tier: 25GB. cloudinary.com
CLOUDINARY_CLOUD_NAME=your-cloud-name
CLOUDINARY_API_KEY=your-api-key
CLOUDINARY_API_SECRET=your-api-secret

# ── Stripe (Global Payments) ────────────────────
# stripe.com → Developers → API Keys
STRIPE_SECRET_KEY=sk_test_your-stripe-secret
STRIPE_WEBHOOK_SECRET=whsec_your-webhook-secret
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_your-publishable-key
# Create in Stripe Dashboard → Products → Add Price
NEXT_PUBLIC_STRIPE_PRO_MONTHLY=price_monthly_id
NEXT_PUBLIC_STRIPE_PRO_YEARLY=price_yearly_id

# ── Razorpay (India Payments) ────────────────────
# razorpay.com → Settings → API Keys
RAZORPAY_KEY_ID=rzp_test_your-key-id
RAZORPAY_KEY_SECRET=your-key-secret
NEXT_PUBLIC_RAZORPAY_KEY_ID=rzp_test_your-key-id
# Create in Razorpay → Subscriptions → Plans
NEXT_PUBLIC_RAZORPAY_PRO_MONTHLY=plan_monthly_id
NEXT_PUBLIC_RAZORPAY_PRO_YEARLY=plan_yearly_id
RAZORPAY_WEBHOOK_SECRET=your-razorpay-webhook-secret

# ── Limits ──────────────────────────────────────
FREE_DAILY_AI_LIMIT=10
FREE_DAILY_PDF_LIMIT=5

# ── Admin ───────────────────────────────────────
ADMIN_EMAIL=admin@pdfaihub.com

# ── Resend (Email Delivery) ─────────────────────
# Get key: resend.com
RESEND_API_KEY=

